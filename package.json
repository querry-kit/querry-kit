{
  "name": "@querry-kit/landing-page",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.15.1",
  "scripts": {
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "dev": "pnpm docs:dev",
    "build": "pnpm docs:build",
    "preview": "pnpm docs:preview",
    "examples:dev": "pnpm --filter @querry-kit/example-workboard-api dev",
    "examples:check": "pnpm --filter @querry-kit/example-workboard-api typecheck && pnpm examples:build",
    "examples:build": "pnpm -r --filter './examples/**' build",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^16.5.0",
    "prettier": "^3.8.2",
    "typescript-eslint": "^8.47.0",
    "vitepress": "^1.6.4"
  }
}
