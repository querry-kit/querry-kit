{
  "name": "@querry-kit/landing-page",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.15.1",
  "scripts": {
    "docs:dev": "pnpm --dir apps/docs dev",
    "docs:lint": "pnpm --dir apps/docs lint",
    "docs:typecheck": "pnpm --dir apps/docs typecheck",
    "docs:build": "pnpm --dir apps/docs build",
    "docs:preview": "pnpm --dir apps/docs preview",
    "docs:test": "pnpm --dir apps/docs test",
    "dev": "pnpm docs:dev",
    "build": "pnpm docs:build",
    "preview": "pnpm docs:preview",
    "examples:dev": "pnpm --filter @querry-kit/example-workboard-api dev",
    "examples:check": "pnpm --filter @querry-kit/example-workboard-api typecheck && pnpm examples:build",
    "examples:build": "pnpm -r --filter './examples/**' build",
    "lint": "eslint . --config eslint.config.mjs --max-warnings=0",
    "lint:fix": "eslint . --config eslint.config.mjs --fix",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.7.0",
    "prettier": "^3.8.2",
    "typescript-eslint": "^8.47.0"
  }
}
